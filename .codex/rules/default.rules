prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
    justification = "Project tasks require a verified git commit when each task is completed.",
    match = [
        "git commit -m update-settings",
        "git commit --message update-settings",
    ],
    not_match = [
        "git push",
    ],
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
    justification = "Project tasks require staging verified changes before committing.",
    match = [
        "git add AGENTS.md",
        "git add .codex/rules/default.rules",
    ],
    not_match = [
        "git status",
        "git push",
    ],
)
